{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM"],
		"strict": true,
		"noEmit": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"types": ["bun", "node"],
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"devos-server/*": ["../server/src/*"]
		}
	},
	"include": ["src", "tests", "../../devos.config.ts"]
}
